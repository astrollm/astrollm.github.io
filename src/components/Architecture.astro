---
const steps = [
  {
    title: 'Query',
    description: '"What do we know about TRAPPIST-1e\'s atmosphere?"',
    isQuery: true,
  },
  {
    title: 'Retrieve',
    lines: [
      'Search 15M+ papers via NASA ADS',
      'Resolve objects via SIMBAD (20.5M astronomical objects)',
      'Cross-reference with NASA Exoplanet Archive',
    ],
  },
  {
    title: 'Reason',
    lines: [
      'Fine-tuned astronomy model interprets evidence',
      'Adapts explanation depth to your level',
    ],
  },
  {
    title: 'Cite',
    lines: [
      'Every claim linked to source papers',
      'ADS bibcodes trace back to the literature',
    ],
  },
];
---

<section class="architecture">
  <div class="architecture__inner">
    <span class="section-label">How It Works</span>
    <h2 class="architecture__headline">Retrieve. Reason. Cite.</h2>

    <ol class="architecture__flow">
      {steps.map((step, i) => (
        <li class={`architecture__step ${step.isQuery ? 'architecture__step--query' : ''}`}>
          <div class="architecture__step-marker" aria-hidden="true">
            <div class="architecture__step-dot"></div>
            {i < steps.length - 1 && <div class="architecture__connector-line"></div>}
          </div>
          <div class="architecture__step-body">
            <div class="architecture__step-title">{step.title}</div>
            {step.isQuery ? (
              <p class="architecture__step-query">{step.description}</p>
            ) : (
              <div class="architecture__step-lines">
                {step.lines?.map((line) => (
                  <p>{line}</p>
                ))}
              </div>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .architecture {
    padding: 8rem 2rem;
  }

  .architecture__inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .architecture__headline {
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 3.5rem;
  }

  .architecture__flow {
    display: flex;
    flex-direction: column;
    list-style: none;
  }

  .architecture__step {
    display: flex;
    gap: 1.25rem;
  }

  .architecture__step-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.3rem;
    flex-shrink: 0;
  }

  .architecture__step-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-blue-dim);
  }

  .architecture__step--query .architecture__step-dot {
    background: var(--border-subtle);
  }

  .architecture__step-body {
    flex: 1;
  }

  .architecture__step-title {
    font-family: "IBM Plex Mono", monospace;
    font-size: 15px;
    font-weight: 500;
    color: var(--accent-blue);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .architecture__step--query .architecture__step-title {
    color: var(--text-tertiary);
  }

  .architecture__step-query {
    font-style: italic;
    font-weight: 400;
    color: var(--text-secondary);
    font-size: 19px;
  }

  .architecture__step-lines p {
    font-size: 18px;
    font-weight: 400;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .architecture__connector-line {
    width: 1px;
    flex: 1;
    min-height: 1.5rem;
    background: repeating-linear-gradient(
      to bottom,
      var(--border-subtle) 0px,
      var(--border-subtle) 3px,
      transparent 3px,
      transparent 6px
    );
  }
</style>
