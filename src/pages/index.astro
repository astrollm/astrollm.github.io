---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FadeIn from '../components/FadeIn.astro';
import Vision from '../components/Vision.astro';
import Architecture from '../components/Architecture.astro';
import Models from '../components/Models.astro';
import DataSources from '../components/DataSources.astro';
import Roadmap from '../components/Roadmap.astro';
import OpenSource from '../components/OpenSource.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <main>
    <Hero />

    <FadeIn>
      <Vision />
    </FadeIn>

    <FadeIn>
      <Architecture />
    </FadeIn>

    <FadeIn>
      <Models />
    </FadeIn>

    <FadeIn>
      <DataSources />
    </FadeIn>

    <FadeIn>
      <Roadmap />
    </FadeIn>

    <FadeIn>
      <OpenSource />
    </FadeIn>

    <Footer />
  </main>
</Layout>
